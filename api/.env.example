# api/.env.example — template for environment variable overrides
# Copy this file to api/.env and fill in real values. api/.env is git-ignored.

# Project root path (default: /mnt/data/fx-model-api/api)
BASE_DIR=/opt/fx-model-api-1h

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Model version (shown in /status; bump when deploying a new model)
MODEL_VERSION=hybrid_model_4

# MongoDB (authenticated; user needs readWrite on the target db)
MONGO_URI=mongodb://USER:PASSWORD@localhost:27017/?authSource=fx_model
MONGO_DB=fx_model